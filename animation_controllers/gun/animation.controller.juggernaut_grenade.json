{
    "animation_controllers": {
        "controller.animation.grenade": {
            "initial_state": "setup",
            "states": {
                "default": {
                    "on_entry": [
                        "/event entity @s unshoot",
                        "/tag @s add holdgun"
                    ],
                    "transitions": [
                        {
                            "hold": "variable.delaygrenadebeh = 0.45; variable.previous_timegrenadebeh = query.life_time; return (q.is_using_item && query.get_equipped_item_name == 'frag_grenade' && !q.is_riding && q.health > 0 && q.mark_variant ==0);"
                        },
                        {
                            "setup": "!q.is_item_name_any('slot.weapon.mainhand', 0, 'mw:frag_grenade') || !q.is_using_item"
                        }
                    ]
                },
                "hold": {
                    "transitions": [
                        {
                            "setup": "!q.is_item_name_any('slot.weapon.mainhand', 0, 'mw:frag_grenade') || !q.is_using_item"
                        },
                        {
                            "hold2": "(query.life_time - variable.previous_timegrenadebeh ) >= variable.delaygrenadebeh && q.is_using_item"
                        }
                    ]
                },
                "hold2": {
                    "on_entry": [
                        "/scoreboard players set @s grenade 40",
                        "/tag @s add grenade"
                    ],
                    "transitions": [
                        {
                            "throw": "!q.is_using_item"
                        }
                    ]
                },
                "setup": {
                    "on_entry": [
                        "/event entity @s unshoot",
                        "/tag @s remove holdgun",
                        "/scoreboard players set @s grenade 0",
                        "/tag @s remove grenade"
                    ],
                    "transitions": [
                        {
                            "default": "query.get_equipped_item_name('main_hand') == 'frag_grenade' && q.is_using_item"
                        }
                    ]
                },
                "throw": {
