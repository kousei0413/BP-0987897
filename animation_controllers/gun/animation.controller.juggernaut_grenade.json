                        "/execute @s[tag=ghost] ~~~ playsound ghost.grenade2 @a[rm=1,r=40] ~~~ 1 1 0.5",
                        "/camerashake add @s 0.1 0.05 rotational",
                        "/camerashake add @s 0.03 0.4 rotational",
